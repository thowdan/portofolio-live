# Copy these into your Vercel project's Environment Variables (Settings → Environment
# Variables), or into a local .env file for `vercel dev`. None are needed for the
# PUBLIC site to render — it falls back to built-in default content. They ARE needed
# for the admin editor to log in and save.

# --- Admin login (required to use /admin) ---
# Backup password. Primary login is an email + password you set inside the admin
# (stored in Neon); this password-only login is the fallback used if the database
# is ever unreachable. Choose a strong value.
ADMIN_PASSWORD=change-me-to-a-strong-password

# A long random string used to sign admin session cookies. Recommended.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET= 

# --- Content storage (required to SAVE edits) ---
# Free Postgres from Neon: https://console.neon.tech → create a project →
# "Connection Details" → copy the connection string (use the "Pooled connection"
# one). It looks like: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=
 